generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  fullName  String
  nim       String   @unique
  email     String   @unique
  password  String
  role      String   @default("student")
  photoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments            Payment[]
  academics           Academic[]
  krsItems            Krs[]
  notifications       Notification[]
  resetTokens PasswordResetToken[]
}

model Announcement {
  id          Int      @id @default(autoincrement())
  category    String
  title       String
  description String
  date        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Payment {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  amount    Int
  status    String   @default("unpaid")
  method    String?
  paidAt    String?
  dueDate   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Academic {
  id        Int      @id @default(autoincrement())
  userId    Int
  semester  String
  sks       Int
  ips       Float
  ipk       Float
  krsStatus String   @default("belum disetujui")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Course {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  credits   Int
  lecturer  String
  semester  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  krsItems Krs[]
}

model Krs {
  id        Int      @id @default(autoincrement())
  userId    Int
  courseId  Int
  semester  String
  status    String   @default("diambil")
  approval  String   @default("pending")
  adminNote String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, semester])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  emailSent Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
